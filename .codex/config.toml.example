# Agent0 - Codex MCP recipes + optional hooks
#
# This is NOT a complete Codex project config and Agent0
# does not own model, provider, sandbox, approval, or tool-permission defaults.
#
# Workflow:
#   1. cp .codex/config.toml.example .codex/config.toml
#   2. Default: put secrets in .codex/.env.local (gitignored), not in this file.
#   3. Flip enabled = true only for the MCP recipes you want active.
#   4. Start Codex with: bash .agent0/tools/codex-local-env.sh
#      Or export the required env vars before running codex directly.
#
# Full recipe docs: .claude/rules/mcp-recipes.md
#
# Optional Agent0 hooks:
#   Uncomment the [features] + [[hooks.*]] block below after copying this file
#   to .codex/config.toml and trusting repo-local hooks. The commands resolve
#   from the git root because Codex may start in a subdirectory.

# [features]
# hooks = true

# [[hooks.SessionStart]]
# matcher = "startup|resume|clear|compact"
# [[hooks.SessionStart.hooks]]
# type = "command"
# command = 'bash "$(git rev-parse --show-toplevel)/.agent0/hooks/session-start.sh"'
# statusMessage = "Reading session handoff"

# [[hooks.SessionStart]]
# matcher = "startup|resume|clear|compact"
# [[hooks.SessionStart.hooks]]
# type = "command"
# command = 'bash "$(git rev-parse --show-toplevel)/.agent0/hooks/memory-decay-readout.sh"'
# statusMessage = "Reading project-memory decay"

# [[hooks.SessionStart]]
# matcher = "startup|resume|clear|compact"
# [[hooks.SessionStart.hooks]]
# type = "command"
# command = 'bash "$(git rev-parse --show-toplevel)/.agent0/hooks/reminders-readout.sh"'
# statusMessage = "Reading reminders"

# [[hooks.SessionStart]]
# matcher = "startup|resume|clear|compact"
# [[hooks.SessionStart.hooks]]
# type = "command"
# command = 'bash "$(git rev-parse --show-toplevel)/.agent0/hooks/routines-readout.sh"'
# statusMessage = "Reading routine queue"

# [[hooks.Stop]]
# [[hooks.Stop.hooks]]
# type = "command"
# command = 'bash "$(git rev-parse --show-toplevel)/.agent0/hooks/session-stop.sh"'
# statusMessage = "Checking session handoff"

# [[hooks.PostToolUse]]
# matcher = "^apply_patch$"
# [[hooks.PostToolUse.hooks]]
# type = "command"
# command = 'bash "$(git rev-parse --show-toplevel)/.agent0/hooks/session-track-edits.sh"'
# statusMessage = "Tracking session edits"

# [[hooks.PreToolUse]]
# matcher = "^apply_patch$"
# [[hooks.PreToolUse.hooks]]
# type = "command"
# command = 'bash "$(git rev-parse --show-toplevel)/.agent0/hooks/memory-index-gate.sh"'
# statusMessage = "Checking project-memory index"

# [[hooks.PostToolUse]]
# matcher = "^apply_patch$"
# [[hooks.PostToolUse.hooks]]
# type = "command"
# command = 'bash "$(git rev-parse --show-toplevel)/.agent0/hooks/memory-frontmatter-validate.sh"'
# statusMessage = "Validating project-memory frontmatter"
# [[hooks.PostToolUse.hooks]]
# type = "command"
# command = 'bash "$(git rev-parse --show-toplevel)/.agent0/hooks/memory-events-journal.sh"'
# statusMessage = "Projecting project-memory index"

# Governance safety floor (spec 107). PreToolUse(Bash) blocks common-obvious
# destructive ops (rm -r+-f, git push --force, reset --hard, clean -fdx,
# whole-tree checkout/restore), hook bypass (--no-verify), and blanket staging.
# Identical block semantics on Codex (reads only tool_input.command). Override:
# `# OVERRIDE: <reason ≥10 chars>`. Speed-bump, not a sandbox.
# [[hooks.PreToolUse]]
# matcher = "^Bash$"
# [[hooks.PreToolUse.hooks]]
# type = "command"
# command = 'bash "$(git rev-parse --show-toplevel)/.agent0/hooks/governance-gate.sh"'
# statusMessage = "Checking destructive-op safety floor"

# Delegation observability (spec 106). SubagentStart audits the dispatch
# (non-blocking — Codex cannot block a spawn); SubagentStop appends the close
# row. Both write the single canonical .agent0/delegation-audit.jsonl. The
# 5-field handoff discipline itself is convention-only on Codex (no hook
# enforces it — see .claude/rules/delegation.md § Codex: convention-only).
# [[hooks.SubagentStart]]
# [[hooks.SubagentStart.hooks]]
# type = "command"
# command = 'bash "$(git rev-parse --show-toplevel)/.agent0/hooks/delegation-start-audit.sh"'
# statusMessage = "Auditing subagent dispatch"

# [[hooks.SubagentStop]]
# [[hooks.SubagentStop.hooks]]
# type = "command"
# command = 'bash "$(git rev-parse --show-toplevel)/.agent0/hooks/delegation-stop.sh"'
# statusMessage = "Closing delegation audit row"

[mcp_servers.playwright]
enabled = false
command = "npx"
args = ["-y", "@playwright/mcp@latest"]

[mcp_servers.chrome-devtools]
enabled = false
command = "npx"
args = ["-y", "chrome-devtools-mcp@latest"]

[mcp_servers.dbhub]
enabled = false
command = "npx"
args = ["-y", "@bytebase/dbhub@latest"]
env_vars = ["DATABASE_URL"]

[mcp_servers.laravel-boost]
enabled = false
command = "php"
args = ["artisan", "boost:mcp"]

[mcp_servers.next-devtools]
enabled = false
command = "npx"
args = ["-y", "next-devtools-mcp@latest"]

[mcp_servers.fal-ai]
enabled = false
url = "https://mcp.fal.ai/mcp"
bearer_token_env_var = "FAL_KEY"
