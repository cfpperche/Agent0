---
import Doc from "../../layouts/Doc.astro";
import ThemeView from "../../components/ThemeView.astro";
import { THEMES } from "../../i18n/capacities";
const locale = "en" as const;
const theme = THEMES.find((t) => t.id === "spec-workflow")!;
---

<Doc locale={locale} title={`${theme.name[locale]} — Agent0`} description={theme.blurb[locale]}>
  <ThemeView themeId="spec-workflow" locale={locale} />
</Doc>
