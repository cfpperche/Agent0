---
import { STRINGS } from "../i18n/strings";
import CodeBlock from "./CodeBlock.astro";
import type { Locale } from "../i18n/locales";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = STRINGS[locale].quickStart;
---

<section id="quickstart" class="border-t border-[var(--color-line)] bg-[var(--color-surface)]">
  <div class="mx-auto max-w-4xl px-5 py-20 md:px-8 md:py-28">
    <p class="mb-3 font-mono text-xs uppercase tracking-[0.18em] text-[var(--color-accent)]">
      {t.eyebrow}
    </p>
    <h2 class="font-sans text-3xl font-semibold tracking-tight text-[var(--color-ink)] md:text-4xl">
      {t.title}
    </h2>
    <p class="mt-4 max-w-2xl text-base leading-relaxed text-[var(--color-ink-soft)]">
      {t.intro}
    </p>
    <ol class="mt-10 space-y-8">
      {
        t.steps.map((step, idx) => (
          <li class="grid grid-cols-[auto_1fr] gap-5">
            <span class="flex h-8 w-8 items-center justify-center rounded-full border border-[var(--color-line-strong)] font-mono text-xs text-[var(--color-ink-muted)]">
              {String(idx + 1).padStart(2, "0")}
            </span>
            <div class="min-w-0">
              <h3 class="font-sans text-lg font-semibold text-[var(--color-ink)]">
                {step.title}
              </h3>
              <p class="mt-1.5 text-[var(--color-ink-soft)]">{step.body}</p>
              {step.code && (
                <div class="mt-4">
                  <CodeBlock code={step.code} filename="terminal" />
                </div>
              )}
            </div>
          </li>
        ))
      }
    </ol>
    <p class="mt-10 border-l-2 border-[var(--color-accent)] pl-4 text-sm leading-relaxed text-[var(--color-ink-soft)]">
      {t.finalNote}
    </p>
  </div>
</section>
