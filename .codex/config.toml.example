# type = "command"
# command = 'bash "$(git rev-parse --show-toplevel)/.agent0/hooks/memory-frontmatter-validate.sh"'
# statusMessage = "Validating project-memory frontmatter"
# [[hooks.PostToolUse.hooks]]
# type = "command"
# command = 'bash "$(git rev-parse --show-toplevel)/.agent0/hooks/memory-events-journal.sh"'
# statusMessage = "Projecting project-memory index"

[mcp_servers.playwright]
enabled = false
command = "npx"
args = ["-y", "@playwright/mcp@latest"]

[mcp_servers.chrome-devtools]
enabled = false
command = "npx"
args = ["-y", "chrome-devtools-mcp@latest"]

[mcp_servers.dbhub]
enabled = false
command = "npx"
args = ["-y", "@bytebase/dbhub@latest"]
env_vars = ["DATABASE_URL"]

[mcp_servers.laravel-boost]
enabled = false
command = "php"
args = ["artisan", "boost:mcp"]

[mcp_servers.next-devtools]
enabled = false
command = "npx"
args = ["-y", "next-devtools-mcp@latest"]

[mcp_servers.fal-ai]
enabled = false
url = "https://mcp.fal.ai/mcp"
bearer_token_env_var = "FAL_KEY"
