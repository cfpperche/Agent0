{
  "name": "tachyon",
  "displayName": "Tachyon",
  "description": "Multi-agent terminal orchestration \u2014 signals from the future. Run AI coding agents as tmux sessions in native editor terminals, coordinated through the Bridge MCP server.",
  "version": "0.1.0",
  "publisher": "cfpperche",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/cfpperche/Agent0.git",
    "directory": "packages/tachyon"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "ai",
    "agents",
    "tmux",
    "terminal",
    "mcp",
    "orchestration"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:tachyon.yml"
  ],
  "contributes": {
    "commands": [
      {
        "command": "tachyon.start",
        "title": "Tachyon: Start"
      },
      {
        "command": "tachyon.stopAll",
        "title": "Tachyon: Stop All"
      },
      {
        "command": "tachyon.restartAgent",
        "title": "Tachyon: Restart Agent"
      },
      {
        "command": "tachyon.openAgentTerminal",
        "title": "Tachyon: Open Agent Terminal"
      },
      {
        "command": "tachyon.applyLayout",
        "title": "Tachyon: Apply Layout"
      },
      {
        "command": "tachyon.copyBridgeUrl",
        "title": "Tachyon: Copy Bridge URL"
      },
      {
        "command": "tachyon.copyBridgeToken",
        "title": "Tachyon: Copy Bridge Token"
      },
      {
        "command": "tachyon.connectRuntime",
        "title": "Tachyon: Connect Agent Runtime"
      },
      {
        "command": "tachyon.refreshViews",
        "title": "Tachyon: Refresh Views",
        "icon": "$(refresh)"
      },
      {
        "command": "tachyon.spawnAgentItem",
        "title": "Start Agent",
        "icon": "$(play)"
      },
      {
        "command": "tachyon.killAgentItem",
        "title": "Stop Agent",
        "icon": "$(debug-stop)"
      },
      {
        "command": "tachyon.restartAgentItem",
        "title": "Restart Agent",
        "icon": "$(debug-restart)"
      },
      {
        "command": "tachyon.openAgentTerminalItem",
        "title": "Open Agent Terminal"
      },
      {
        "command": "tachyon.addPin",
        "title": "Tachyon: Add Pin",
        "icon": "$(add)"
      },
      {
        "command": "tachyon.openNotes",
        "title": "Tachyon: Open Notes",
        "icon": "$(notebook)"
      },
      {
        "command": "tachyon.deletePinItem",
        "title": "Delete Pin",
        "icon": "$(trash)"
      },
      {
        "command": "tachyon.newAgent",
        "title": "Tachyon: New Agent",
        "icon": "$(add)"
      },
      {
        "command": "tachyon.cloneAgentItem",
        "title": "Clone Agent\u2026"
      },
      {
        "command": "tachyon.editAgentItem",
        "title": "Edit in tachyon.yml"
      },
      {
        "command": "tachyon.renameAgentItem",
        "title": "Rename Agent\u2026"
      },
      {
        "command": "tachyon.deleteAgentItem",
        "title": "Delete Agent\u2026"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tachyon",
          "title": "Tachyon",
          "icon": "media/tachyon.svg"
        }
      ]
    },
    "views": {
      "tachyon": [
        {
          "id": "tachyonAgents",
          "name": "Agents",
          "icon": "media/tachyon.svg"
        },
        {
          "id": "tachyonLayouts",
          "name": "Layouts",
          "icon": "media/tachyon.svg"
        },
        {
          "id": "tachyonPins",
          "name": "Pins",
          "icon": "media/tachyon.svg"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "tachyon.refreshViews",
          "when": "view == tachyonAgents || view == tachyonLayouts || view == tachyonPins",
          "group": "navigation"
        },
        {
          "command": "tachyon.addPin",
          "when": "view == tachyonPins",
          "group": "navigation@1"
        },
        {
          "command": "tachyon.openNotes",
          "when": "view == tachyonPins",
          "group": "navigation@2"
        },
        {
          "command": "tachyon.newAgent",
          "when": "view == tachyonAgents",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "tachyon.spawnAgentItem",
          "when": "view == tachyonAgents && viewItem == agent-stopped",
          "group": "inline"
        },
        {
          "command": "tachyon.killAgentItem",
          "when": "view == tachyonAgents && (viewItem == agent-running || viewItem == agent-crashed)",
          "group": "inline"
        },
        {
          "command": "tachyon.restartAgentItem",
          "when": "view == tachyonAgents && (viewItem == agent-running || viewItem == agent-crashed)",
          "group": "inline"
        },
        {
          "command": "tachyon.deletePinItem",
          "when": "view == tachyonPins && viewItem == pin",
          "group": "inline"
        },
        {
          "command": "tachyon.editAgentItem",
          "when": "view == tachyonAgents && viewItem =~ /^agent-/",
          "group": "2_manage@1"
        },
        {
          "command": "tachyon.cloneAgentItem",
          "when": "view == tachyonAgents && viewItem =~ /^agent-/",
          "group": "2_manage@2"
        },
        {
          "command": "tachyon.renameAgentItem",
          "when": "view == tachyonAgents && viewItem =~ /^agent-/",
          "group": "2_manage@3"
        },
        {
          "command": "tachyon.deleteAgentItem",
          "when": "view == tachyonAgents && viewItem =~ /^agent-/",
          "group": "2_manage@4"
        }
      ],
      "commandPalette": [
        {
          "command": "tachyon.spawnAgentItem",
          "when": "false"
        },
        {
          "command": "tachyon.killAgentItem",
          "when": "false"
        },
        {
          "command": "tachyon.restartAgentItem",
          "when": "false"
        },
        {
          "command": "tachyon.openAgentTerminalItem",
          "when": "false"
        },
        {
          "command": "tachyon.deletePinItem",
          "when": "false"
        },
        {
          "command": "tachyon.cloneAgentItem",
          "when": "false"
        },
        {
          "command": "tachyon.editAgentItem",
          "when": "false"
        },
        {
          "command": "tachyon.renameAgentItem",
          "when": "false"
        },
        {
          "command": "tachyon.deleteAgentItem",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Tachyon",
      "properties": {
        "tachyon.maxAgents": {
          "type": "number",
          "default": 8,
          "minimum": 1,
          "description": "Maximum number of concurrently running agents per workspace (fork-bomb guardrail). tachyon.yml settings.maxAgents takes precedence when set."
        }
      }
    },
    "yamlValidation": [
      {
        "fileMatch": [
          "tachyon.yml",
          "tachyon.yaml"
        ],
        "url": "./dist/tachyon.schema.json"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vscode-test",
    "package": "vsce package"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.96.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "esbuild": "^0.25.0",
    "mocha": "^11.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
