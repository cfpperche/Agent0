---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { type Locale } from "../i18n/locales";
import Maintenance from "../components/Maintenance.astro";
import { UNDER_CONSTRUCTION } from "../config";

interface Props {
  locale: Locale;
  title: string;
  description: string;
}

const { locale, title, description } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const siteUrl = "https://cfpperche.github.io";
const homeHref = `${base}/${locale}/`;
const canonical = `${siteUrl}${Astro.url.pathname}`;
---

<!doctype html>
{UNDER_CONSTRUCTION ? <Maintenance locale={locale} /> : (
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${siteUrl}${base}/og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${base}/og-image.png`} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  </head>
  <body class="min-h-screen overflow-x-clip antialiased">
    <a
      href="#top"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-[var(--color-ink)] focus:px-3 focus:py-2 focus:text-sm focus:text-[var(--color-bg)]"
    >
      Skip to content
    </a>
    <Header locale={locale} anchorBase={homeHref} />
    <main id="top">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
)}
