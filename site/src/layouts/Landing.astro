---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import CapacityGrid from "../components/CapacityGrid.astro";
import WhyBuilt from "../components/WhyBuilt.astro";
import QuickStart from "../components/QuickStart.astro";
import HowToExtend from "../components/HowToExtend.astro";
import Faq from "../components/Faq.astro";
import Footer from "../components/Footer.astro";
import { STRINGS } from "../i18n/strings";
import { LOCALES, type Locale } from "../i18n/locales";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const meta = STRINGS[locale].meta;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const siteUrl = "https://cfpperche.github.io";
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteUrl}${base}/${locale}/`} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    {
      LOCALES.map((loc) => (
        <link rel="alternate" hreflang={loc} href={`${siteUrl}${base}/${loc}/`} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${base}/en/`} />
  </head>
  <body class="min-h-screen overflow-x-clip antialiased">
    <a href="#top" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-[var(--color-ink)] focus:px-3 focus:py-2 focus:text-sm focus:text-[var(--color-bg)]">
      Skip to content
    </a>
    <Header locale={locale} />
    <main>
      <Hero locale={locale} />
      <CapacityGrid locale={locale} />
      <WhyBuilt locale={locale} />
      <QuickStart locale={locale} />
      <HowToExtend locale={locale} />
      <Faq locale={locale} />
    </main>
    <Footer locale={locale} />
  </body>
</html>
