    "prepublishOnly": "bun scripts/sync-open-design.ts --verify"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
