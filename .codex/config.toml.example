# Agent0 - Codex MCP recipes
#
# MCP-only template. This is NOT a complete Codex project config and Agent0
# does not own model, provider, sandbox, approval, or tool-permission defaults.
#
# Workflow:
#   1. cp .codex/config.toml.example .codex/config.toml
#   2. Default: put secrets in .codex/.env.local (gitignored), not in this file.
#   3. Flip enabled = true only for the MCP recipes you want active.
#   4. Start Codex with: bash .claude/tools/codex-local-env.sh
#      Or export the required env vars before running codex directly.
#
# Full recipe docs: .claude/rules/mcp-recipes.md
#
# Optional project-memory hooks:
#   Uncomment the [features] + [[hooks.*]] block below after copying this file
#   to .codex/config.toml and trusting repo-local hooks. The commands resolve
#   from the git root because Codex may start in a subdirectory.

# [features]
# hooks = true

# [[hooks.SessionStart]]
# matcher = "startup|resume|clear|compact"
# [[hooks.SessionStart.hooks]]
# type = "command"
# command = 'bash "$(git rev-parse --show-toplevel)/.agent0/hooks/memory-decay-readout.sh"'
# statusMessage = "Reading project-memory decay"

# [[hooks.SessionStart]]
# matcher = "startup|resume|clear|compact"
# [[hooks.SessionStart.hooks]]
# type = "command"
# command = 'bash "$(git rev-parse --show-toplevel)/.agent0/hooks/reminders-readout.sh"'
# statusMessage = "Reading reminders"

# [[hooks.SessionStart]]
# matcher = "startup|resume|clear|compact"
# [[hooks.SessionStart.hooks]]
# type = "command"
# command = 'bash "$(git rev-parse --show-toplevel)/.agent0/hooks/routines-readout.sh"'
# statusMessage = "Reading routine queue"

# [[hooks.PreToolUse]]
# matcher = "^apply_patch$"
# [[hooks.PreToolUse.hooks]]
