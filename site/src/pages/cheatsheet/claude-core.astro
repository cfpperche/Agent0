---
import "../../styles/global.css";
import { REPO_URL } from "../../i18n/locales";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const siteUrl = "https://cfpperche.github.io";
const CC_VERSION = "2.1.143";
const pageTitle = `Claude Code · Core Cheatsheet · v${CC_VERSION}`;
const pageDesc = `One-page poster reference for Claude Code v${CC_VERSION}: CLI flags, settings, hooks lifecycle, skills, agents, rules, slash commands.`;
---

<!doctype html>
<html lang="en" data-theme="poster">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={`${siteUrl}${base}/cheatsheet/claude-core/`} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  </head>
  <body class="poster-body">
    <a href={`${base}/en/`} class="back-link">← back to Agent0</a>

    <main class="poster">
      <!-- ===== TOP BANNER ===== -->
      <header class="banner">
        <div class="banner-strip">
          <span class="strip-tag">▮ AGENT0 CONTROL ROOM</span>
          <span class="strip-tag">CLAUDE CODE v{CC_VERSION}</span>
          <span class="strip-tag">CORE REFERENCE — CHEATSHEET ▮</span>
        </div>
        <h1 class="title">
          <span class="title-line">CLAUDE CODE</span>
          <span class="title-line title-accent">CHEATSHEET</span>
        </h1>
        <p class="tag">
          CLI · SETTINGS · HOOKS · SKILLS · AGENTS · RULES · COMMANDS
        </p>
        <p class="subtag">
          Every surface of <code>claude</code> on one page. Built against
          <code>v{CC_VERSION}</code>.
        </p>
      </header>

      <!-- ===== PART I HEADER ===== -->
      <div class="part-marker">
        <span class="part-tag">PART I</span>
        <span class="part-h">CLI — the runtime surface</span>
        <span class="part-dim">flags, modes, subcommands</span>
      </div>

      <!-- ===== GRID ===== -->
      <section class="grid">
        <!-- EXECUTION MODES -->
        <article class="card card-green" style="grid-area: modes">
          <h2 class="card-h">▸ EXECUTION MODES</h2>
          <p class="card-sub">how the session is shaped</p>
          <dl class="flags">
            <dt><span class="dim">(default)</span></dt>
            <dd>Interactive REPL. The 90% case.</dd>
            <dt><code>-p, --print</code> <span class="arg">[prompt]</span></dt>
            <dd>One-shot. Print and exit. For pipes, scripts, CI.</dd>
            <dt><code>-c, --continue</code></dt>
            <dd>Resume the <b>last</b> conversation in this dir.</dd>
            <dt><code>-r, --resume</code> <span class="arg">[id|search]</span></dt>
            <dd>Pick a session (interactive picker if no arg).</dd>
            <dt><code>--fork-session</code></dt>
            <dd>With <code>-c</code>/<code>-r</code>: branch a new session id.</dd>
            <dt><code>--session-id</code> <span class="arg">&lt;uuid&gt;</span></dt>
            <dd>Force a deterministic UUID. For integrations.</dd>
            <dt><code>--from-pr</code> <span class="arg">[N|url]</span></dt>
            <dd>Resume the session linked to a PR.</dd>
          </dl>
        </article>

        <!-- MODEL & EFFORT -->
        <article class="card card-orange" style="grid-area: model">
          <h2 class="card-h">▸ MODEL &amp; EFFORT</h2>
          <p class="card-sub">how much brain to bring</p>
          <dl class="flags">
            <dt><code>--model</code> <span class="arg">&lt;alias|id&gt;</span></dt>
            <dd><code>opus</code> · <code>sonnet</code> · <code>haiku</code> · full id.</dd>
            <dt><code>--effort</code> <span class="arg">&lt;level&gt;</span></dt>
            <dd>low · medium · high · xhigh · max</dd>
            <dt><code>--fallback-model</code> <span class="arg">&lt;m&gt;</span></dt>
            <dd>Auto-fallback if overloaded. <code>--print</code> only.</dd>
          </dl>
          <div class="recipe">
            <span class="recipe-h">when to escalate →</span>
            architecture review · exploratory debug · multi-source compare ⇒ <code>opus</code>
          </div>
        </article>

        <!-- PERMISSIONS & SAFETY -->
        <article class="card card-red" style="grid-area: perms">
          <h2 class="card-h">▸ PERMISSIONS &amp; SAFETY</h2>
          <p class="card-sub">what the agent can touch</p>
          <dl class="flags">
            <dt><code>--permission-mode</code> <span class="arg">&lt;mode&gt;</span></dt>
            <dd>
              <span class="kv">default</span> ask ·
              <span class="kv">acceptEdits</span> auto-edit ·
              <span class="kv">auto</span> classifier-gated all ·
              <span class="kv">plan</span> plan mode ·
              <span class="kv">dontAsk</span> · <span class="kv warn">bypassPermissions</span>
            </dd>
            <dt class="hot">⇧ <code>Shift+Tab</code></dt>
            <dd>Cycle permission mode in-session. The one shortcut every user uses every day.</dd>
            <dt>protected paths</dt>
            <dd>
              <code>.git</code> · <code>.vscode</code> · <code>.claude</code> · <code>.mcp.json</code> · <code>.claude.json</code> never auto-approved
              (only <span class="kv warn">bypassPermissions</span> overrides).
            </dd>
            <dt><code>--allowedTools</code> <span class="arg">&lt;list&gt;</span></dt>
            <dd>Whitelist. Ex: <code>"Bash(git *) Edit"</code></dd>
            <dt><code>--disallowedTools</code> <span class="arg">&lt;list&gt;</span></dt>
            <dd>Blacklist by name or pattern.</dd>
            <dt><code>--tools</code> <span class="arg">&lt;list&gt;</span></dt>
            <dd>Restrict the built-in set. <code>""</code> = none, <code>default</code> = all.</dd>
            <dt><code>--add-dir</code> <span class="arg">&lt;dirs...&gt;</span></dt>
            <dd>Extra dirs the tools may touch (monorepo).</dd>
            <dt class="warn">
              <code>--dangerously-skip-permissions</code>
            </dt>
            <dd>Bypass everything. Sandbox-without-internet only.</dd>
            <dt><code>--allow-dangerously-skip-permissions</code></dt>
            <dd>Enables the toggle UI without activating it.</dd>
          </dl>
        </article>

        <!-- CONFIG & CONTEXT -->
        <article class="card card-cyan" style="grid-area: config">
          <h2 class="card-h">▸ CONFIG &amp; CONTEXT</h2>
          <p class="card-sub">what the agent loads on start</p>
          <dl class="flags two-col">
            <dt><code>--settings</code> <span class="arg">&lt;file|json&gt;</span></dt>
            <dd>Extra settings (file or inline JSON).</dd>
            <dt><code>--setting-sources</code> <span class="arg">user,project,local</span></dt>
            <dd>Which layers to load. Isolate for tests.</dd>
            <dt><code>--mcp-config</code> <span class="arg">&lt;files&gt;</span></dt>
            <dd>Load MCP servers from JSON.</dd>
            <dt><code>--strict-mcp-config</code></dt>
            <dd>Ignore other MCP sources. Repro-bug mode.</dd>
            <dt><code>--plugin-dir</code> <span class="arg">&lt;path&gt;</span></dt>
            <dd>Session-only plugin (dir or .zip). Repeatable.</dd>
            <dt><code>--plugin-url</code> <span class="arg">&lt;url&gt;</span></dt>
            <dd>Session-only plugin from URL.</dd>
            <dt><code>--agent</code> <span class="arg">&lt;name&gt;</span></dt>
            <dd>Override the session agent.</dd>
            <dt><code>--agents</code> <span class="arg">'&lt;json&gt;'</span></dt>
            <dd>Define custom agents inline.</dd>
            <dt><code>--system-prompt</code> <span class="arg">&lt;s&gt;</span></dt>
            <dd>REPLACE default system prompt. <code>--print</code> only.</dd>
            <dt><code>--append-system-prompt</code> <span class="arg">&lt;s&gt;</span></dt>
            <dd>EXTEND default. Safer than replace.</dd>
            <dt><code>--exclude-dynamic-system-prompt-sections</code></dt>
            <dd>Moves cwd/env to first user msg → cache reuse.</dd>
          </dl>
        </article>

        <!-- SPECIAL MODES -->
        <article class="card card-magenta" style="grid-area: special">
          <h2 class="card-h">▸ SPECIAL MODES</h2>
          <p class="card-sub">change the whole posture</p>
          <dl class="flags">
            <dt><code>--bare</code></dt>
            <dd>
              MINIMAL: no hooks, no LSP, no plugins, no auto-mem,
              no CLAUDE.md discovery. Auth = <code>ANTHROPIC_API_KEY</code>.
              You supply context explicitly.
            </dd>
            <dt><code>--brief</code></dt>
            <dd>Enable <code>SendUserMessage</code> tool (agent → user).</dd>
            <dt><code>-w, --worktree</code> <span class="arg">[name]</span></dt>
            <dd>Spin a git worktree → isolated branch.</dd>
            <dt><code>--tmux</code></dt>
            <dd>tmux pane for the worktree (needs <code>-w</code>).</dd>
            <dt><code>--ide</code></dt>
            <dd>Auto-connect to IDE if exactly one is up.</dd>
            <dt><code>--chrome</code> / <code>--no-chrome</code></dt>
            <dd>Toggle Claude-in-Chrome.</dd>
            <dt><code>--remote-control</code> <span class="arg">[name]</span></dt>
            <dd>Interactive session with Remote Control on.</dd>
            <dt><code>--betas</code> <span class="arg">&lt;h...&gt;</span></dt>
            <dd>Beta headers. API key users only.</dd>
          </dl>
        </article>

        <!-- I/O & FORMAT -->
        <article class="card card-yellow" style="grid-area: io">
          <h2 class="card-h">▸ I/O &amp; FORMAT</h2>
          <p class="card-sub">automation surface · <code>--print</code> only</p>
          <dl class="flags">
            <dt><code>--output-format</code> <span class="arg">text|json|stream-json</span></dt>
            <dd>Single result vs realtime stream.</dd>
            <dt><code>--input-format</code> <span class="arg">text|stream-json</span></dt>
            <dd>stream-json = realtime stdin.</dd>
            <dt><code>--include-partial-messages</code></dt>
            <dd>Stream message chunks as they arrive.</dd>
            <dt><code>--include-hook-events</code></dt>
            <dd>Inject hook lifecycle into the stream.</dd>
            <dt><code>--replay-user-messages</code></dt>
            <dd>Re-emit user msgs for ack. stream↔stream.</dd>
            <dt><code>--json-schema</code> <span class="arg">'&lt;schema&gt;'</span></dt>
            <dd>Structured output, schema-validated.</dd>
            <dt><code>--max-budget-usd</code> <span class="arg">&lt;n&gt;</span></dt>
            <dd>Hard cap. Critical in CI/batch.</dd>
            <dt><code>--no-session-persistence</code></dt>
            <dd>Don't save to disk. Ephemeral scripts.</dd>
          </dl>
        </article>

        <!-- MISC -->
        <article class="card card-violet" style="grid-area: misc">
          <h2 class="card-h">▸ MISC &amp; DEBUG</h2>
          <p class="card-sub">small but useful</p>
          <dl class="flags">
            <dt><code>-d, --debug</code> <span class="arg">[filter]</span></dt>
            <dd>e.g. <code>"api,hooks"</code> or <code>"!1p,!file"</code></dd>
            <dt><code>--debug-file</code> <span class="arg">&lt;path&gt;</span></dt>
            <dd>Debug → file (implies <code>--debug</code>).</dd>
            <dt><code>--verbose</code></dt>
            <dd>Override config verbose.</dd>
            <dt><code>-n, --name</code> <span class="arg">&lt;s&gt;</span></dt>
            <dd>Session display name. Shows in picker + title bar.</dd>
            <dt><code>--disable-slash-commands</code></dt>
            <dd>Kill all skills. Extreme sandbox.</dd>
            <dt><code>--file</code> <span class="arg">&lt;id:path&gt;</span></dt>
            <dd>Download file resources at startup.</dd>
            <dt><code>-h, --help</code> · <code>-v, --version</code></dt>
            <dd>Obvious.</dd>
            <dt class="dim"><code>--mcp-debug</code></dt>
            <dd class="dim">DEPRECATED → use <code>--debug</code>.</dd>
          </dl>
        </article>

        <!-- SUBCOMMANDS -->
        <article class="card card-pink" style="grid-area: sub">
          <h2 class="card-h">▸ SUBCOMMANDS</h2>
          <p class="card-sub"><code>claude &lt;cmd&gt; ...</code></p>
          <dl class="flags">
            <dt><code>auth</code></dt>
            <dd>Login / logout. Manage credentials.</dd>
            <dt><code>setup-token</code></dt>
            <dd>Long-lived token (Claude subscription).</dd>
            <dt><code>agents</code></dt>
            <dd>Manage background agents.</dd>
            <dt><code>mcp</code></dt>
            <dd>Configure / manage MCP servers.</dd>
            <dt><code>plugin</code> · <code>plugins</code></dt>
            <dd>Manage plugins.</dd>
            <dt><code>project</code></dt>
            <dd>Manage project state.</dd>
            <dt><code>auto-mode</code></dt>
            <dd>Inspect auto-mode classifier.</dd>
            <dt><code>doctor</code></dt>
            <dd>Health-check the auto-updater.</dd>
            <dt><code>install</code> <span class="arg">[target]</span></dt>
            <dd>Install native build · stable / latest / version.</dd>
            <dt><code>update</code> · <code>upgrade</code></dt>
            <dd>Check & install update.</dd>
            <dt class="hot"><code>ultrareview</code> <span class="arg">[PR|base]</span></dt>
            <dd>Cloud multi-agent review of branch / PR.</dd>
          </dl>
        </article>

      </section>

      <!-- ===== PART II HEADER ===== -->
      <div class="part-marker">
        <span class="part-tag part-tag-orange">PART II</span>
        <span class="part-h">Platform — what you configure in <code>.claude/</code></span>
        <span class="part-dim">settings · hooks · skills · agents · rules · commands</span>
      </div>

      <!-- ===== PLATFORM GRID ===== -->
      <section class="grid grid-platform">

        <!-- SETTINGS -->
        <article class="card card-orange" style="grid-area: settings">
          <h2 class="card-h">▸ SETTINGS — <code>settings.json</code></h2>
          <p class="card-sub">precedence chain · TOP WINS</p>
          <ol class="chain">
            <li><code>managed / enterprise policy</code> <span class="arg">MDM-installed · highest authority</span></li>
            <li><code>--settings &lt;file|json&gt;</code> <span class="arg">CLI flag · per-invocation override</span></li>
            <li><code>&lt;proj&gt;/.claude/settings.local.json</code> <span class="arg">project-local · gitignored</span></li>
            <li><code>&lt;proj&gt;/.claude/settings.json</code> <span class="arg">project · git-tracked, ships to team</span></li>
            <li><code>~/.claude/settings.json</code> <span class="arg">user-global · per-machine</span></li>
          </ol>
          <p class="card-sub" style="margin-top:10px">top-level keys</p>
          <dl class="flags two-col">
            <dt><code>permissions</code></dt>
            <dd><code>defaultMode</code> · <code>allow[]</code> · <code>deny[]</code> · <code>additionalDirectories[]</code></dd>
            <dt><code>hooks</code></dt>
            <dd>per-event arrays of <code>&#123;matcher, hooks:[&#123;type:"command", command&#125;]&#125;</code></dd>
            <dt><code>model</code></dt>
            <dd>Default model alias (<code>opus</code>/<code>sonnet</code>/<code>haiku</code>).</dd>
            <dt><code>agent</code></dt>
            <dd>Default agent for new sessions.</dd>
            <dt><code>statusLine</code></dt>
            <dd><code>&#123;type:"command", command&#125;</code> — stdout becomes the status bar.</dd>
            <dt><code>env</code></dt>
            <dd>Env vars exported to all CC-spawned processes.</dd>
            <dt><code>mcpServers</code></dt>
            <dd>Inline MCP defs; or use <code>.mcp.json</code> at repo root.</dd>
            <dt><code>enableAllProjectMcpServers</code></dt>
            <dd>Boolean trust gate for <code>.mcp.json</code>.</dd>
            <dt><code>outputStyle</code> · <code>theme</code></dt>
            <dd>UI presets.</dd>
            <dt><code>$schema</code></dt>
            <dd><code>https://json.schemastore.org/claude-code-settings.json</code></dd>
          </dl>
          <div class="snippet">
            <span class="recipe-h"># minimal example</span>
<pre><code>{`{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": { "defaultMode": "default", "allow": ["Bash(git *)"] },
  "hooks": {
    "SessionStart": [{ "hooks": [{ "type": "command",
      "command": "bash .claude/hooks/session-start.sh" }] }]
  }
}`}</code></pre>
          </div>
        </article>

        <!-- HOOKS -->
        <article class="card card-cyan" style="grid-area: hooks">
          <h2 class="card-h">▸ HOOKS — 29 LIFECYCLE EVENTS</h2>
          <p class="card-sub">stdin-JSON in · stdout/stderr + exit-code out</p>

          <div class="hooks-groups">
            <div class="hg">
              <span class="hg-h">▸ session lifecycle</span>
              <code>SessionStart</code> <span class="arg">source: startup·resume·clear·compact</span> ·
              <code>SessionEnd</code> · <code>Setup</code> ·
              <code>Stop</code> · <code>StopFailure</code>
            </div>
            <div class="hg">
              <span class="hg-h">▸ prompt &amp; instructions</span>
              <code>UserPromptSubmit</code> · <code>UserPromptExpansion</code> · <code>InstructionsLoaded</code>
            </div>
            <div class="hg">
              <span class="hg-h">▸ tool gates</span>
              <code>PreToolUse</code> · <code>PostToolUse</code> <span class="arg">on tool success</span> ·
              <code>PostToolUseFailure</code> <span class="arg">on tool failure</span> ·
              <code>PostToolBatch</code>
            </div>
            <div class="hg">
              <span class="hg-h">▸ permission</span>
              <code>PermissionRequest</code> · <code>PermissionDenied</code>
            </div>
            <div class="hg">
              <span class="hg-h">▸ sub-agents &amp; tasks</span>
              <code>SubagentStart</code> · <code>SubagentStop</code> ·
              <code>TaskCreated</code> · <code>TaskCompleted</code>
            </div>
            <div class="hg">
              <span class="hg-h">▸ compaction</span>
              <code>PreCompact</code> · <code>PostCompact</code>
            </div>
            <div class="hg">
              <span class="hg-h">▸ system events</span>
              <code>Notification</code> · <code>TeammateIdle</code> · <code>ConfigChange</code> ·
              <code>CwdChanged</code> · <code>FileChanged</code> ·
              <code>WorktreeCreate</code> · <code>WorktreeRemove</code> ·
              <code>Elicitation</code> · <code>ElicitationResult</code>
            </div>
          </div>

          <div class="hooks-rules">
            <div class="hr-block">
              <span class="recipe-h">payload (stdin JSON)</span>
              <p><code>session_id</code> · <code>transcript_path</code> · <code>tool_name</code> · <code>tool_input</code> · <code>tool_response</code> <span class="arg">PostToolUse only</span> · <code>tool_use_id</code> · <code>hook_event_name</code> · <code>duration_ms</code></p>
            </div>
            <div class="hr-block">
              <span class="recipe-h">exit codes</span>
              <p><code>0</code> = allow · <code>2</code> on <code>PreToolUse</code> = <b>BLOCK</b> (stderr shown to agent) · other = log-only</p>
            </div>
            <div class="hr-block">
              <span class="recipe-h warn">gotcha</span>
              <p><code>PostToolUse(Bash)</code> fires only on tool <b>success</b> (not exit-code — pipes can mask). Pair with <code>PostToolUseFailure(Bash)</code> to cover failures. Payload diverges — failure uses <code>.error</code>, no <code>tool_response</code>.</p>
            </div>
          </div>
        </article>

        <!-- SKILLS -->
        <article class="card card-magenta" style="grid-area: skills">
          <h2 class="card-h">▸ SKILLS — <code>/&lt;name&gt;</code></h2>
          <p class="card-sub">slash commands · prompt-as-markdown</p>
          <dl class="flags">
            <dt>📁 <code>.claude/skills/&lt;name&gt;/SKILL.md</code></dt>
            <dd>project skill (ships in repo).</dd>
            <dt>📁 <code>~/.claude/skills/&lt;name&gt;/SKILL.md</code></dt>
            <dd>user skill (per-machine).</dd>
          </dl>
          <p class="card-sub" style="margin-top:8px">frontmatter</p>
<pre class="fm-pre"><code>{`---
description: One-line discovery hint
argument-hint: <new <slug> | list>
allowed-tools: [Read, Grep, Bash]
disable-model-invocation: false
paths: ["docs/specs/**"]
context: fork           # isolated turn
agent: my-agent         # delegated agent
---
# /name — body is the prompt`}</code></pre>
          <dl class="flags" style="margin-top:8px">
            <dt><code>$ARGUMENTS</code></dt>
            <dd>Raw input after the slash command.</dd>
            <dt><code>$CLAUDE_SKILL_DIR</code></dt>
            <dd>Absolute path to the skill dir (for templates).</dd>
            <dt><code>!`cmd`</code></dt>
            <dd>Inline shell output injected as context when skill loads. Killer feature for live state.</dd>
            <dt>invoke</dt>
            <dd><code>/name args</code> · or the <code>Skill</code> tool.</dd>
            <dt>bundled skills</dt>
            <dd>
              <code>/simplify</code> · <code>/batch</code> · <code>/debug</code> · <code>/loop</code> · <code>/claude-api</code> ship with CC
              (docs-defined, not user-installed).
            </dd>
          </dl>
        </article>

        <!-- AGENTS -->
        <article class="card card-violet" style="grid-area: agents">
          <h2 class="card-h">▸ AGENTS — sub-agents</h2>
          <p class="card-sub">isolated context · single return msg</p>
          <dl class="flags">
            <dt>📁 <code>.claude/agents/&lt;name&gt;.md</code></dt>
            <dd>project agent (ships in repo).</dd>
            <dt>📁 <code>~/.claude/agents/&lt;name&gt;.md</code></dt>
            <dd>user agent.</dd>
          </dl>
          <p class="card-sub" style="margin-top:8px">frontmatter (full)</p>
<pre class="fm-pre"><code>{`---
description: When to delegate to this agent
tools: [Read, Grep, Bash]
disallowedTools: [Edit, Write]
model: sonnet           # alias or full id
permissionMode: plan
skills: [sdd, remind]
mcpServers: [github]
maxTurns: 12
isolation: worktree
---
You are an X agent. Your job is …`}</code></pre>
          <p class="card-sub" style="margin-top:8px">built-in agents</p>
          <ul class="builtins">
            <li><code>general-purpose</code> — open-ended research / multi-step</li>
            <li><code>Explore</code> — fast read-only code search</li>
            <li><code>Plan</code> — architect / implementation plan</li>
            <li><code>claude-code-guide</code> — CC + SDK + API questions</li>
            <li><code>statusline-setup</code> — configure status line</li>
          </ul>
          <p class="card-sub" style="margin-top:8px">dispatch</p>
          <p class="mini">
            <code>Agent</code> tool: <code>subagent_type</code> + <code>prompt</code> +
            optional <code>model</code> · <code>isolation:"worktree"</code> · <code>run_in_background</code>.
          </p>
        </article>

        <!-- RULES -->
        <article class="card card-pink" style="grid-area: rules">
          <h2 class="card-h">▸ RULES — <code>.claude/rules/</code></h2>
          <p class="card-sub">behavioral mandates · path-scoped optional</p>
          <dl class="flags">
            <dt>📁 <code>.claude/rules/&lt;topic&gt;.md</code></dt>
            <dd>git-tracked · ships to forks via harness-sync.</dd>
            <dt>frontmatter (optional)</dt>
            <dd>
              <code>paths: ["**/foo.sh", "**/bar.md"]</code> — load only when
              accessed file matches a glob. Fires <code>InstructionsLoaded</code>
              with <code>load_reason: path_glob_match</code>.
            </dd>
            <dt>vs <b>memory</b></dt>
            <dd><code>.claude/memory/</code> = factual reference (DOES NOT ship). Rules = behavior (DOES ship).</dd>
            <dt>vs <b>CLAUDE.md</b></dt>
            <dd>Always loaded; canonical orientation. Rules are on-demand, deeper.</dd>
            <dt>load reasons</dt>
            <dd><code>session_start</code> · <code>path_glob_match</code> · <code>nested_traversal</code> · <code>include</code> · <code>compact</code></dd>
          </dl>
          <p class="mini" style="margin-top:8px">
            Dedup: one <code>InstructionsLoaded</code> per rule per session,
            no matter how many globs match later.
          </p>
        </article>

