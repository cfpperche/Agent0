{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Tachyon (demo)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${userHome}/tachyon-demo",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "tachyon: build"
    },
    {
      "name": "Run Tachyon (test fixture)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${workspaceFolder}/test/fixtures/sample-workspace",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "tachyon: build"
    }
  ]
}
