---
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { STRINGS } from "../i18n/strings";
import { REPO_URL, type Locale } from "../i18n/locales";

interface Props {
  locale: Locale;
  // When set (doc/sub-pages), in-page anchors resolve against the landing instead
  // of the current page. Default "" = landing (bare `#anchor`).
  anchorBase?: string;
}

const { locale, anchorBase = "" } = Astro.props;
const t = STRINGS[locale].nav;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const logoHref = anchorBase || "#top";
---

<header class="sticky top-0 z-50 border-b border-[var(--color-line)] bg-[var(--color-bg)]/85 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-3 md:px-8">
    <a href={logoHref} class="font-mono text-sm font-semibold tracking-tight">
      <span class="text-[var(--color-ink)]">agent0</span><span class="text-[var(--color-accent)]">_</span>
    </a>
    <nav class="hidden items-center gap-5 text-sm text-[var(--color-ink-soft)] md:flex">
      <a href={`${anchorBase}#capacities`} class="hover:text-[var(--color-ink)]">{t.capacities}</a>
      <a href={`${anchorBase}#mcps`} class="hover:text-[var(--color-ink)]">{t.mcps}</a>
      <a href={`${anchorBase}#why`} class="hover:text-[var(--color-ink)]">{t.whyBuilt}</a>
      <a href={`${anchorBase}#quickstart`} class="hover:text-[var(--color-ink)]">{t.quickStart}</a>
      <a href={`${anchorBase}#extend`} class="hover:text-[var(--color-ink)]">{t.howToExtend}</a>
      <a href={`${anchorBase}#faq`} class="hover:text-[var(--color-ink)]">{t.faq}</a>
    </nav>
    <div class="flex items-center gap-3">
      <LanguageSwitcher locale={locale} />
      <a
        href={REPO_URL}
        target="_blank"
        rel="noopener"
        class="hidden items-center gap-1.5 rounded-sm border border-[var(--color-line-strong)] px-3 py-1.5 text-xs font-mono text-[var(--color-ink-soft)] transition hover:border-[var(--color-ink)] hover:text-[var(--color-ink)] md:inline-flex"
      >
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38v-1.34c-2.23.48-2.7-1.07-2.7-1.07-.36-.92-.89-1.16-.89-1.16-.73-.5.05-.49.05-.49.81.06 1.23.83 1.23.83.72 1.22 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82A7.66 7.66 0 0 1 8 4.65c.68 0 1.36.09 2 .26 1.53-1.03 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.28.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48v2.19c0 .21.15.46.55.38A8 8 0 0 0 16 8c0-4.42-3.58-8-8-8Z" />
        </svg>
        {t.github}
      </a>
    </div>
  </div>
</header>
