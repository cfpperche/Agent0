# Claude Code — personal config and local state (do not version)
.claude/settings.local.json
CLAUDE.local.md
.claude/projects/
.mcp.json
.codex/config.toml
.codex/.env.local

# Ephemeral state under .claude/ — per-machine runtime, never commit
.agent0/.runtime-state/*
!.agent0/.runtime-state/README.md
.agent0/.session-state/
# OD orphan-prune trash journal (spec 142) — crash-recovery aid, rm'd on success
.claude/skills/product/runtime/od-sync/pruned-*/
.agent0/.delegation-state/
.agent0/delegation-audit.jsonl
.agent0/delegation-audit.jsonl.lock
.agent0/secrets-audit.jsonl
.agent0/secrets-audit.jsonl.lock
.agent0/.propagation-debug.json
.agent0/.context-index/
.agent0/.memory-events.jsonl
.agent0/.memory-events.jsonl.lock
.claude/.memory-events.jsonl
.claude/.memory-events.jsonl.lock
.claude/*.lock
.claude/scheduled_tasks.lock
.agent0/.brainstorm-state/
.agent0/.routines-state/
.agent0/browser-policy.json
.agent0/browser-auth/

# sync-harness CLAUDE.md migration artifacts (ephemeral; ratified via mv,
# divergence reports re-generated each sync until resolved)
.claude/CLAUDE.md.migration-candidate.md
.claude/CLAUDE.md.diverged-region.md
.claude/CLAUDE.md.diverged-sections.md

# Playwright MCP runtime artifacts (snapshots, console logs)
.playwright-mcp/

# Exploratory prototypes (not yet promoted to docs/specs/ or src/)
prototypes/

# Secrets-scan scenario tests run in mktemp /tmp dirs by default, but reserve a
# scratchpad path in case a future test variant needs in-repo state.
.agent0/tests/secrets-scan/.tmp/

# Stack-specific patterns — uncomment whichever applies to your fork.
# Template is stack-agnostic by design; forks add their own.
# (.gitignore does NOT support trailing inline comments — descriptions must
# stay on their own lines above each pattern so uncommenting only the path
# leaves a valid entry.)
#
# JS/TS (npm/pnpm/yarn/bun)
# node_modules/
#
# Python (uv/poetry/pdm/raw venv)
# .venv/
# __pycache__/
# .pytest_cache/
# .mypy_cache/
# .ruff_cache/
#
# Rust (cargo)
# target/
#
# Go (legacy) / PHP / Ruby
# vendor/

# Visual-audit screenshots — evidence captured by playwright MCP; conversation is the memory
/audit-*.png

# Image-gen generated output — draft assets and per-machine call manifest are local (spec 147).
assets/generated/.manifest.jsonl
assets/generated/mockups/*
!assets/generated/mockups/.gitkeep

# Video-gen renders — regenerable MP4s (spec 132). Composition source at
# assets/video/compositions/* stays tracked; the .video-manifest.jsonl stays tracked.
assets/generated/videos/*
!assets/generated/videos/.gitkeep

# Transcribe — local STT (spec 159). User content + engine/model cache stay local.
# Transcripts are the user's content (never auto-committed); the provenance
# manifest + the whisper engine/model cache are per-machine.
assets/transcripts/*
!assets/transcripts/.gitkeep
assets/generated/.transcribe-manifest.jsonl
.agent0/.runtime-state/transcribe/

# Audio — local TTS synthesis (spec 160). Draft previews + engine/voice cache +
# manifest are per-machine; the tracked voiceover dir assets/audio/ is NOT ignored
# (kept assets are committable, mirroring /image's brand vs mockups split).
assets/generated/audio/*
!assets/generated/audio/.gitkeep
assets/generated/.audio-manifest.jsonl
.agent0/.runtime-state/audio/
