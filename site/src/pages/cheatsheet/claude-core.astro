          <span class="b-tag">DRIVE THE CLI</span>
          <span class="sep">|</span>
          <span class="b-tag">CONFIGURE THE PLATFORM</span>
          <span class="sep">|</span>
          <span class="b-tag">SHIP THE DISCIPLINE</span>
        </div>
        <div class="meta">
          Sources: <code>claude --help</code> · <a href="https://code.claude.com/docs/en/hooks" target="_blank" rel="noopener">hooks docs</a> · <a href="https://code.claude.com/docs/en/commands" target="_blank" rel="noopener">commands docs</a> · Hosted by
          <a href={`${base}/en/`}>Agent0</a> ·
          <a href={REPO_URL} target="_blank" rel="noopener">github/cfpperche/Agent0</a>
        </div>
      </footer>
    </main>

    <style is:global>
      :root[data-theme="poster"] {
        --p-bg: #0a0e1f;
        --p-bg-2: #0e1530;
        --p-ink: #e5e7eb;
        --p-ink-dim: #9ca3af;
        --p-ink-faint: #6b7280;
        --p-green: #39ff14;
        --p-orange: #ff9933;
        --p-red: #ff4d4d;
        --p-cyan: #00e5ff;
        --p-magenta: #ff44ff;
        --p-yellow: #ffd700;
        --p-violet: #9b87f5;
        --p-pink: #ff5cad;
      }

      html[data-theme="poster"],
      html[data-theme="poster"] body {
        background: var(--p-bg) !important;
        color: var(--p-ink) !important;
      }

      .poster-body {
        font-family: var(--font-mono);
        background:
          radial-gradient(ellipse at top, rgba(57, 255, 20, 0.04), transparent 60%),
          radial-gradient(ellipse at bottom right, rgba(255, 153, 51, 0.04), transparent 60%),
          var(--p-bg);
        min-height: 100vh;
        color: var(--p-ink);
        padding: 16px;
      }

      .back-link {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--p-ink-dim);
        padding: 6px 10px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 3px;
        margin-bottom: 12px;
        transition: all 120ms ease;
      }
      .back-link:hover {
        color: var(--p-green);
        border-color: var(--p-green);
      }

      .poster {
        max-width: 1400px;
        margin: 0 auto;
        background: var(--p-bg);
        border: 1px solid rgba(255, 255, 255, 0.08);
        padding: 32px 28px;
      }

      /* ===== BANNER ===== */
      .banner {
        text-align: center;
        border: 1px solid rgba(57, 255, 20, 0.3);
        padding: 24px 16px 28px;
        background: linear-gradient(180deg, rgba(57, 255, 20, 0.04), transparent);
        margin-bottom: 24px;
      }
      .banner-strip {
        display: flex;
        justify-content: space-between;
        font-size: 10px;
        letter-spacing: 0.18em;
        color: var(--p-ink-dim);
        margin-bottom: 18px;
        flex-wrap: wrap;
        gap: 8px;
      }
      .strip-tag {
        font-family: var(--font-mono);
      }

      .title {
        font-family: var(--font-mono);
        font-weight: 800;
        font-size: clamp(32px, 8.5vw, 96px);
        line-height: 0.95;
        letter-spacing: 0.04em;
        margin: 0;
        text-shadow:
          0 0 24px rgba(57, 255, 20, 0.35),
          0 2px 0 rgba(0, 0, 0, 0.6);
      }
      .title-line {
        display: block;
        white-space: nowrap;
      }
      .title-line {
        color: var(--p-green);
      }
      .title-accent {
        color: var(--p-orange);
        text-shadow:
          0 0 24px rgba(255, 153, 51, 0.45),
          0 2px 0 rgba(0, 0, 0, 0.6);
      }

      .tag {
        margin: 18px 0 6px;
        font-size: 14px;
        letter-spacing: 0.16em;
        color: var(--p-ink);
      }
      .subtag {
        margin: 0;
        font-size: 13px;
        color: var(--p-ink-dim);
      }
      .subtag code {
        color: var(--p-green);
        background: rgba(57, 255, 20, 0.08);
        padding: 1px 6px;
        border-radius: 2px;
      }

      /* ===== PART MARKER ===== */
      .part-marker {
        margin: 28px 0 12px;
        padding: 10px 14px;
        border-left: 4px solid var(--p-green);
        background: linear-gradient(90deg, rgba(57, 255, 20, 0.08), transparent);
        display: flex;
        align-items: baseline;
        gap: 14px;
        flex-wrap: wrap;
      }
      .part-tag {
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.2em;
        font-weight: 800;
        color: var(--p-bg);
        background: var(--p-green);
        padding: 2px 8px;
        border-radius: 2px;
      }
      .part-tag-orange {
        background: var(--p-orange);
      }
      .part-marker.orange {
        border-left-color: var(--p-orange);
        background: linear-gradient(90deg, rgba(255, 153, 51, 0.08), transparent);
      }
      .part-h {
        font-family: var(--font-mono);
        font-size: 15px;
        font-weight: 600;
        color: var(--p-ink);
      }
      .part-h code {
        color: var(--p-green);
        background: rgba(57, 255, 20, 0.08);
        padding: 0 4px;
        border-radius: 2px;
        font-size: 13px;
      }
      .part-dim {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--p-ink-faint);
        letter-spacing: 0.06em;
      }

      /* ===== GRID — CLI (PART I) ===== */
      .grid {
        display: grid;
        gap: 14px;
        grid-template-columns: repeat(3, 1fr);
        grid-template-areas:
          "modes   model    perms"
          "config  config   special"
          "io      misc     sub";
      }
      @media (max-width: 1000px) {
        .grid {
          grid-template-columns: repeat(2, 1fr);
          grid-template-areas:
            "modes   model"
            "perms   special"
            "config  config"
            "io      misc"
            "sub     sub";
        }
      }
      @media (max-width: 640px) {
        .grid {
          grid-template-columns: 1fr;
          grid-template-areas:
            "modes" "model" "perms"
            "config" "special"
            "io" "misc" "sub";
        }
        .poster { padding: 18px 14px; }
        .banner { padding: 16px 8px 18px; }
        .title { font-size: clamp(28px, 11vw, 56px); }
        .tag { font-size: 12px; letter-spacing: 0.12em; }
        .subtag { font-size: 11px; }
      }

      /* ===== GRID — PLATFORM (PART II) ===== */
      .grid-platform {
        grid-template-columns: repeat(3, 1fr);
        grid-template-areas:
          "settings settings hooks"
          "settings settings hooks"
          "skills   agents   rules"
          "commands commands commands"
          "envvars  envvars  envvars";
      }
      @media (max-width: 1000px) {
        .grid-platform {
          grid-template-columns: repeat(2, 1fr);
          grid-template-areas:
            "settings hooks"
            "skills   agents"
            "rules    rules"
            "commands commands"
            "envvars  envvars";
        }
      }
      @media (max-width: 640px) {
        .grid-platform {
          grid-template-columns: 1fr;
          grid-template-areas:
            "settings" "hooks"
            "skills" "agents" "rules"
            "commands"
            "envvars";
        }
      }

      /* ENV VARS — reuse cmd-cols but in green */
      .env-cols .cmd-h {
        color: var(--p-green);
        border-bottom-color: rgba(57, 255, 20, 0.25);
      }
      .env-cols .cmd-list li code {
        color: var(--p-green);
        background: rgba(57, 255, 20, 0.06);
      }

      /* ===== RECIPES SECTION ===== */
      .recipes-section {
        margin-top: 18px;
      }

      /* ===== PART III MARKER (cyan variant) ===== */
      .part-marker-cyan {
        border-left-color: var(--p-cyan);
        background: linear-gradient(90deg, rgba(0, 229, 255, 0.08), transparent);
      }
      .part-tag-cyan {
        background: var(--p-cyan);
      }
      .part-marker-cyan .part-h code {
        color: var(--p-cyan);
        background: rgba(0, 229, 255, 0.08);
      }

      /* ===== LIFECYCLE SECTION ===== */
      .lifecycle-section {
        margin-top: 14px;
      }
      .diagram-wrap {
        margin: 12px 0 16px;
        overflow-x: auto;
        padding-bottom: 4px;
        scrollbar-color: var(--p-cyan) rgba(0,0,0,0.3);
      }
      .lifecycle-svg {
        display: block;
        width: 100%;
        min-width: 900px;
        height: auto;
        font-family: var(--font-mono);
      }

      /* SVG — lifelines */
      .lifelines line {
        stroke: rgba(255, 255, 255, 0.18);
        stroke-width: 1;
        stroke-dasharray: 4 4;
      }

      /* SVG — phase bands */
      .band {
        fill: rgba(255, 255, 255, 0.015);
        stroke: rgba(255, 255, 255, 0.06);
        stroke-width: 1;
      }
      .band-input { fill: rgba(57, 255, 20, 0.04); }
      .band-model { fill: rgba(0, 229, 255, 0.04); }
      .band-loop  { fill: rgba(255, 153, 51, 0.04); stroke: rgba(255, 153, 51, 0.18); stroke-dasharray: 5 4; }
      .band-sub   { fill: rgba(155, 135, 245, 0.05); }
      .band-stop  { fill: rgba(255, 215, 0, 0.04); }

      .phase-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.14em;
        fill: var(--p-ink);
      }
      .loop-hint {
        font-size: 10px;
        font-weight: 400;
        letter-spacing: 0.04em;
        fill: var(--p-orange);
      }

      /* SVG — lane headers */
      .lane-box {
        fill: rgba(0, 0, 0, 0.4);
        stroke: rgba(255, 255, 255, 0.25);
        stroke-width: 1;
      }
      .lane-box.user  { stroke: var(--p-green);   fill: rgba(57, 255, 20, 0.1); }
      .lane-box.orch  { stroke: var(--p-orange);  fill: rgba(255, 153, 51, 0.1); }
      .lane-box.hooks { stroke: var(--p-cyan);    fill: rgba(0, 229, 255, 0.1); }
      .lane-box.model { stroke: var(--p-magenta); fill: rgba(255, 68, 255, 0.1); }
      .lane-box.tool  { stroke: var(--p-yellow);  fill: rgba(255, 215, 0, 0.1); }
      .lane-box.sub   { stroke: var(--p-violet);  fill: rgba(155, 135, 245, 0.1); }

      .lane-label {
        font-size: 11.5px;
        font-weight: 800;
        letter-spacing: 0.14em;
        fill: var(--p-ink);
        text-anchor: middle;
      }
      .lane-sub {
        font-size: 9px;
        fill: var(--p-ink-faint);
        text-anchor: middle;
        letter-spacing: 0.06em;
      }

      /* SVG — messages (arrows) */
      .msg {
        stroke: var(--p-ink);
        stroke-width: 1.4;
        color: var(--p-ink);
        fill: none;
      }
      .msg.dashed {
        stroke-dasharray: 3 3;
        stroke: var(--p-ink-dim);
        color: var(--p-ink-dim);
      }
      .msg-d {
        stroke: rgba(156, 163, 175, 0.5);
        stroke-width: 1;
        stroke-dasharray: 2 3;
        color: rgba(156, 163, 175, 1);
        fill: none;
      }
      .msg-label {
        font-size: 10px;
        fill: var(--p-ink);
        text-anchor: middle;
        letter-spacing: 0.02em;
      }
      .note {
        font-size: 10px;
        fill: var(--p-ink-faint);
        font-style: italic;
      }
      .emph {
        fill: var(--p-violet);
        font-weight: 700;
      }

      /* SVG — hook badges */
      .hook-badge rect {
        fill: rgba(0, 229, 255, 0.12);
        stroke: var(--p-cyan);
        stroke-width: 0.8;
        rx: 2;
      }
      .hook-badge text {
        font-size: 10px;
        font-weight: 600;
        fill: var(--p-cyan);
        text-anchor: middle;
        letter-spacing: 0.02em;
      }
      .hook-badge.ok rect {
        fill: rgba(57, 255, 20, 0.12);
        stroke: var(--p-green);
      }
      .hook-badge.ok text { fill: var(--p-green); }
      .hook-badge.warn rect {
        fill: rgba(255, 77, 77, 0.12);
        stroke: var(--p-red);
      }
      .hook-badge.warn text { fill: var(--p-red); }
      .hook-badge.dim rect {
        fill: rgba(255, 255, 255, 0.04);
        stroke: rgba(255, 255, 255, 0.2);
      }
      .hook-badge.dim text { fill: var(--p-ink-dim); }

      .if {
        font-size: 9px;
        font-weight: 400;
        fill: var(--p-ink-faint);
        font-style: italic;
      }
      .block-tag {
        font-size: 9px;
        font-weight: 700;
        fill: var(--p-red);
        letter-spacing: 0.1em;
      }

      /* SVG — loop arrow */
      .loop-arrow {
        stroke: var(--p-orange);
        stroke-width: 1.6;
        stroke-dasharray: 6 3;
        fill: none;
        color: var(--p-orange);
      }
      .loop-label {
        font-size: 9.5px;
        letter-spacing: 0.08em;
        font-weight: 600;
        fill: var(--p-orange);
        text-anchor: middle;
      }

      /* ===== LEGEND ===== */
      .lifecycle-legend {
        display: grid;
        gap: 10px;
        grid-template-columns: repeat(3, 1fr);
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px dashed rgba(255, 255, 255, 0.08);
      }
      @media (max-width: 900px) {
        .lifecycle-legend { grid-template-columns: 1fr; }
      }
      .lg-block ul {
        list-style: none;
        padding: 0;
        margin: 4px 0 0;
      }
      .lg-block li {
        font-size: 11px;
        color: var(--p-ink-dim);
        line-height: 1.6;
        padding: 1px 0;
      }
      .lg-block code {
        color: var(--p-cyan);
        background: rgba(0, 229, 255, 0.06);
        padding: 0 4px;
        border-radius: 2px;
        font-size: 10.5px;
      }
      .lg-h {
        display: block;
        font-family: var(--font-mono);
        font-size: 10.5px;
        letter-spacing: 0.12em;
        font-weight: 700;
        color: var(--p-cyan);
        margin-bottom: 4px;
        padding-bottom: 4px;
        border-bottom: 1px dashed rgba(0, 229, 255, 0.25);
      }
      .lg-swatch {
        display: inline-block;
        width: 10px;
        height: 10px;
        border-radius: 2px;
        vertical-align: middle;
        margin-right: 4px;
      }
      .lg-swatch.ok   { background: var(--p-green); }
      .lg-swatch.warn { background: var(--p-red); }
      .lg-arr {
        display: inline-block;
        width: 14px;
        color: var(--p-ink);
        font-weight: 700;
      }
      .lg-arr.d { color: var(--p-ink-dim); }
      .lg-arr.l { color: var(--p-orange); }

      /* ===== CARDS ===== */
      .card {
        --c: var(--p-green);
        border: 1px solid var(--c);
        background: rgba(10, 14, 31, 0.6);
        padding: 14px 16px 16px;
        position: relative;
      }
      .card::before {
        content: "";
        position: absolute;
        inset: 0;
        border: 1px solid rgba(255, 255, 255, 0.04);
        pointer-events: none;
      }
      .card-green   { --c: var(--p-green); }
      .card-orange  { --c: var(--p-orange); }
      .card-red     { --c: var(--p-red); }
      .card-cyan    { --c: var(--p-cyan); }
      .card-magenta { --c: var(--p-magenta); }
      .card-yellow  { --c: var(--p-yellow); }
      .card-violet  { --c: var(--p-violet); }
      .card-pink    { --c: var(--p-pink); }

      .card-h {
        font-family: var(--font-mono);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.14em;
        color: var(--c);
        margin: 0 0 2px;
        text-shadow: 0 0 12px color-mix(in srgb, var(--c) 40%, transparent);
      }
      .card-sub {
        font-size: 11px;
        color: var(--p-ink-faint);
        margin: 0 0 12px;
        letter-spacing: 0.04em;
      }

      /* ===== FLAGS DL ===== */
      .flags {
        margin: 0;
        display: grid;
        gap: 6px 12px;
      }
      .flags.two-col {
        grid-template-columns: 1fr;
      }
      @media (min-width: 720px) {
        .flags.two-col { grid-template-columns: 1fr 1fr; }
      }

      .flags dt {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--p-ink);
        margin-top: 4px;
        line-height: 1.3;
      }
      .flags dt code {
        color: color-mix(in srgb, var(--c) 85%, white);
        font-weight: 600;
      }
      .flags dt.warn code,
      .flags dt.warn {
        color: var(--p-red) !important;
      }
      .flags dt.hot code {
        color: var(--p-orange);
      }
      .flags dt.dim code,
      .flags dt.dim {
        color: var(--p-ink-faint);
        text-decoration: line-through;
      }

      .flags dd {
        margin: 0 0 4px 14px;
        font-size: 11.5px;
        color: var(--p-ink-dim);
        line-height: 1.5;
      }
      .flags dd.dim { color: var(--p-ink-faint); }
      .flags dd code {
        color: var(--p-green);
        background: rgba(57, 255, 20, 0.06);
        padding: 0 4px;
        border-radius: 2px;
        font-size: 11px;
      }
      .arg {
        color: var(--p-ink-faint);
        font-weight: 400;
      }
      .kv {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 10.5px;
        color: var(--p-cyan);
        background: rgba(0, 229, 255, 0.08);
        border: 1px solid rgba(0, 229, 255, 0.25);
        padding: 0 4px;
        margin: 1px 2px 1px 0;
        border-radius: 2px;
      }
      .kv.warn {
        color: var(--p-red);
        background: rgba(255, 77, 77, 0.08);
        border-color: rgba(255, 77, 77, 0.3);
      }
      .dim {
        color: var(--p-ink-faint);
      }

      .recipe {
        margin-top: 10px;
        font-size: 11px;
        color: var(--p-ink-dim);
        padding-top: 10px;
        border-top: 1px dashed rgba(255, 255, 255, 0.08);
      }
      .recipe-h {
        display: block;
        color: var(--p-ink-faint);
        font-size: 10px;
        letter-spacing: 0.08em;
        margin-bottom: 4px;
      }
      .recipe code {
        color: var(--p-orange);
      }

      /* ===== SETTINGS — chain + snippet ===== */
      .chain {
        list-style: none;
        margin: 4px 0 6px;
        padding: 0;
        counter-reset: chain;
      }
      .chain li {
        position: relative;
        padding: 4px 4px 4px 26px;
        font-size: 12px;
        color: var(--p-ink);
        counter-increment: chain;
        border-bottom: 1px dashed rgba(255, 255, 255, 0.05);
      }
      .chain li:last-child { border-bottom: none; }
      .chain li::before {
        content: counter(chain);
        position: absolute;
        left: 0;
        top: 4px;
        font-family: var(--font-mono);
        font-size: 10px;
        font-weight: 700;
        color: var(--p-orange);
        background: rgba(255, 153, 51, 0.1);
        border: 1px solid rgba(255, 153, 51, 0.3);
        width: 18px;
        height: 18px;
        line-height: 16px;
        text-align: center;
        border-radius: 2px;
      }
      .chain code {
        color: var(--p-orange);
        background: rgba(255, 153, 51, 0.08);
        padding: 0 4px;
        border-radius: 2px;
        font-size: 11.5px;
      }
      .snippet {
        margin-top: 10px;
        padding: 8px 10px;
        background: rgba(0, 0, 0, 0.35);
        border-left: 2px solid var(--p-orange);
        font-size: 11px;
      }
      .snippet pre {
        margin: 4px 0 0;
        overflow-x: auto;
        white-space: pre;
        color: var(--p-ink);
      }
      .snippet pre code {
        background: none;
        color: var(--p-ink);
      }

      /* ===== HOOKS — groups + rules ===== */
      .hooks-groups {
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-bottom: 12px;
      }
      .hg {
        font-size: 11.5px;
        line-height: 1.65;
        color: var(--p-ink-dim);
        padding-left: 8px;
        border-left: 2px solid rgba(0, 229, 255, 0.25);
      }
      .hg-h {
        display: block;
        font-family: var(--font-mono);
        font-size: 10.5px;
        letter-spacing: 0.1em;
        font-weight: 700;
        color: var(--p-cyan);
        margin-bottom: 2px;
      }
      .hg code {
        color: var(--p-ink);
        background: rgba(0, 229, 255, 0.06);
        border: 1px solid rgba(0, 229, 255, 0.2);
        padding: 1px 4px;
        margin: 1px 1px 1px 0;
        border-radius: 2px;
        font-size: 10.5px;
        display: inline-block;
        white-space: nowrap;
      }
      .hooks-rules {
        display: grid;
        gap: 8px;
        grid-template-columns: repeat(3, 1fr);
        padding-top: 8px;
        border-top: 1px dashed rgba(255, 255, 255, 0.08);
      }
      @media (max-width: 900px) {
        .hooks-rules { grid-template-columns: 1fr; }
      }
      .hr-block p {
        margin: 4px 0 0;
        font-size: 11px;
        color: var(--p-ink-dim);
        line-height: 1.55;
      }
      .hr-block code {
        color: var(--p-cyan);
        background: rgba(0, 229, 255, 0.06);
        padding: 0 3px;
        border-radius: 2px;
        font-size: 10.5px;
      }
      .recipe-h.warn {
        color: var(--p-red);
      }

      /* ===== SKILLS / AGENTS — frontmatter snippets ===== */
      .fm-pre {
        margin: 4px 0 0;
        padding: 6px 8px;
        background: rgba(0, 0, 0, 0.35);
        border-left: 2px solid var(--c, var(--p-magenta));
        font-size: 10.5px;
        line-height: 1.5;
        color: var(--p-ink);
        overflow-x: auto;
        white-space: pre;
      }
      .fm-pre code {
        background: none;
        color: var(--p-ink);
        font-family: var(--font-mono);
      }
      .builtins {
        list-style: none;
        margin: 4px 0 0;
        padding: 0;
      }
      .builtins li {
        font-size: 11px;
        color: var(--p-ink-dim);
        line-height: 1.6;
        padding-left: 10px;
        position: relative;
      }
      .builtins li::before {
        content: "›";
        color: var(--p-violet);
        position: absolute;
        left: 0;
      }
      .builtins code {
        color: var(--p-violet);
        background: rgba(155, 135, 245, 0.08);
        padding: 0 4px;
        border-radius: 2px;
        font-size: 10.5px;
      }
      .mini {
        font-size: 11px;
        color: var(--p-ink-dim);
        line-height: 1.55;
        margin: 4px 0 0;
      }
      .mini code {
        color: var(--c, var(--p-violet));
        background: rgba(255, 255, 255, 0.04);
        padding: 0 3px;
        border-radius: 2px;
        font-size: 10.5px;
      }

      /* ===== COMMANDS — columns ===== */
      .cmd-cols {
        display: grid;
        gap: 14px 18px;
        grid-template-columns: repeat(4, 1fr);
      }
      @media (max-width: 1100px) {
        .cmd-cols { grid-template-columns: repeat(3, 1fr); }
      }
      @media (max-width: 800px) {
        .cmd-cols { grid-template-columns: repeat(2, 1fr); }
      }
      @media (max-width: 480px) {
        .cmd-cols { grid-template-columns: 1fr; }
      }
      .cmd-h {
        display: block;
        font-family: var(--font-mono);
        font-size: 10.5px;
        letter-spacing: 0.12em;
        font-weight: 700;
        color: var(--p-yellow);
        margin-bottom: 4px;
        padding-bottom: 4px;
        border-bottom: 1px dashed rgba(255, 215, 0, 0.25);
      }
      .cmd-list {
        list-style: none;
        margin: 0;
        padding: 0;
      }
      .cmd-list li {
        font-size: 11px;
        color: var(--p-ink-dim);
        line-height: 1.5;
        padding: 1px 0;
      }
      .cmd-list li code {
        color: var(--p-yellow);
        background: rgba(255, 215, 0, 0.06);
        padding: 0 3px;
        border-radius: 2px;
        font-size: 10.5px;
        margin-right: 4px;
      }
      .cmd-list li.hot code {
        color: var(--p-orange);
        background: rgba(255, 153, 51, 0.08);
      }

      /* ===== RECIPES BLOCK ===== */
      .recipes {
        display: grid;
        gap: 10px;
        grid-template-columns: repeat(2, 1fr);
      }
      @media (max-width: 800px) {
        .recipes { grid-template-columns: 1fr; }
      }
      .recipe-block {
        border-left: 2px solid var(--p-green);
        padding: 6px 10px;
        background: rgba(57, 255, 20, 0.03);
      }
      .recipe-block pre {
        margin: 4px 0 0;
        font-size: 11.5px;
        color: var(--p-ink);
        overflow-x: auto;
        white-space: pre;
      }
      .recipe-block pre code {
        background: none;
        color: var(--p-ink);
        font-family: var(--font-mono);
      }

      /* ===== BOTTOM ===== */
      .bottom {
        margin-top: 24px;
      }
      .bottom-band {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 22px;
        padding: 14px 12px;
        border: 1px solid var(--p-green);
        background: linear-gradient(90deg, rgba(57, 255, 20, 0.06), transparent, rgba(255, 153, 51, 0.06));
        flex-wrap: wrap;
      }
      .b-tag {
        font-family: var(--font-mono);
        font-size: 12px;
        letter-spacing: 0.16em;
        color: var(--p-ink);
        font-weight: 700;
      }
      .sep {
        color: var(--p-ink-faint);
      }
      .meta {
        margin-top: 12px;
        text-align: center;
        font-size: 11px;
        color: var(--p-ink-faint);
        letter-spacing: 0.04em;
      }
      .meta a {
        color: var(--p-green);
      }
      .meta a:hover {
        text-decoration: underline;
      }
      .meta code {
        color: var(--p-orange);
      }

      /* Print stylesheet — one A3 sheet */
      @media print {
        .back-link { display: none; }
        .poster-body { background: white; color: black; padding: 0; }
        .poster {
          border: none;
          padding: 8mm;
          max-width: none;
        }
        .card { background: white; color: black; }
        .flags dt, .flags dd { color: black; }
      }
    </style>
  </body>
</html>
