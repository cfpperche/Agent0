---
import { STRINGS } from "../i18n/strings";
import { REPO_URL, type Locale } from "../i18n/locales";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = STRINGS[locale].hero;
---

<section id="top" class="relative isolate overflow-hidden">
  <div class="mx-auto max-w-6xl px-5 pt-20 pb-24 md:px-8 md:pt-28 md:pb-32">
    <div class="max-w-4xl">
      <p class="mb-6 inline-flex items-center gap-2 rounded-full border border-[var(--color-line-strong)] bg-[var(--color-surface)] px-3 py-1 text-xs font-mono text-[var(--color-ink-muted)]">
        <span class="block h-1.5 w-1.5 rounded-full bg-[var(--color-accent)]"></span>
        {t.eyebrow}
      </p>
      <h1 class="font-sans text-5xl font-semibold leading-[1.05] tracking-tight text-[var(--color-ink)] md:text-7xl">
        {t.title} <br class="hidden md:block" />
        <span class="text-[var(--color-accent)]">{t.titleAccent}</span>
      </h1>
      <p class="mt-7 max-w-2xl text-lg leading-relaxed text-[var(--color-ink-soft)] md:text-xl">
        {t.tagline}
      </p>
      <p class="mt-3 max-w-2xl font-mono text-sm text-[var(--color-ink-muted)]">
        {t.sub}
      </p>
      <div class="mt-9 flex flex-wrap items-center gap-3">
        <a
          href="#quickstart"
          class="inline-flex items-center gap-2 rounded-md bg-[var(--color-ink)] px-5 py-3 text-sm font-medium text-[var(--color-bg)] transition hover:bg-[var(--color-accent-ink)]"
        >
          {t.primaryCta}
          <span aria-hidden="true">→</span>
        </a>
        <a
          href={REPO_URL}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-md border border-[var(--color-line-strong)] bg-[var(--color-surface)] px-5 py-3 text-sm font-medium text-[var(--color-ink)] transition hover:border-[var(--color-ink)]"
        >
          {t.secondaryCta}
          <span aria-hidden="true">↗</span>
        </a>
      </div>
    </div>
    <div class="pointer-events-none absolute -top-32 right-[-10%] -z-10 h-[480px] w-[480px] rounded-full bg-[radial-gradient(circle_at_center,_rgba(99,102,241,0.12),_transparent_60%)]" aria-hidden="true"></div>
    <div class="pointer-events-none absolute top-40 left-[-20%] -z-10 h-[420px] w-[420px] rounded-full bg-[radial-gradient(circle_at_center,_rgba(245,158,11,0.06),_transparent_60%)]" aria-hidden="true"></div>
  </div>
</section>
