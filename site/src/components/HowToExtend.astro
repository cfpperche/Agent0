---
import { STRINGS, EXTEND_CODE } from "../i18n/strings";
import CodeBlock from "./CodeBlock.astro";
import type { Locale } from "../i18n/locales";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = STRINGS[locale].howToExtend;
---

<section id="extend" class="border-t border-[var(--color-line)]">
  <div class="mx-auto max-w-5xl px-5 py-20 md:px-8 md:py-28">
    <p class="mb-3 font-mono text-xs uppercase tracking-[0.18em] text-[var(--color-accent)]">
      {t.eyebrow}
    </p>
    <h2 class="font-sans text-3xl font-semibold tracking-tight text-[var(--color-ink)] md:text-4xl">
      {t.title}
    </h2>
    <p class="mt-4 max-w-2xl text-base leading-relaxed text-[var(--color-ink-soft)]">
      {t.intro}
    </p>
    <div class="mt-10 grid gap-8 md:grid-cols-[1fr_1.1fr] md:gap-12">
      <ol class="min-w-0 space-y-7">
        {
          t.points.map((point, idx) => (
            <li class="min-w-0">
              <div class="flex items-baseline gap-3">
                <span class="font-mono text-xs text-[var(--color-ink-muted)]">
                  {String(idx + 1).padStart(2, "0")}
                </span>
                <h3 class="font-sans text-base font-semibold text-[var(--color-ink)]">
                  {point.title}
                </h3>
              </div>
              <p class="mt-1.5 pl-7 text-sm leading-relaxed text-[var(--color-ink-soft)]">
                {point.body}
              </p>
            </li>
          ))
        }
      </ol>
      <div class="min-w-0">
        <CodeBlock code={EXTEND_CODE} filename="claude-code" />
        <p class="mt-6 border-l-2 border-[var(--color-accent)] pl-4 text-sm italic leading-relaxed text-[var(--color-ink-soft)]">
          {t.closing}
        </p>
      </div>
    </div>
  </div>
</section>
