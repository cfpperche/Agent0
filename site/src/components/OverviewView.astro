---
import { CAPACITIES, THEMES } from "../i18n/capacities";
import { DOC_STRINGS, OVERVIEW_INTRO, OVERVIEW_SECTIONS } from "../i18n/docs";
import { type Locale } from "../i18n/locales";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const d = DOC_STRINGS[locale];
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const themeCount = THEMES.map((t) => ({
  ...t,
  n: CAPACITIES.filter((c) => c.theme === t.id).length,
}));
---

<section class="border-b border-[var(--color-line)] bg-[var(--color-surface)]">
  <div class="mx-auto max-w-3xl px-5 pt-16 pb-12 md:px-8 md:pt-20">
    <a href={`${base}/${locale}/`} class="font-mono text-xs text-[var(--color-ink-muted)] transition hover:text-[var(--color-ink)]">
      {d.backToHome}
    </a>
    <p class="mt-8 mb-3 font-mono text-xs uppercase tracking-[0.18em] text-[var(--color-accent)]">
      {d.overviewEyebrow}
    </p>
    <h1 class="font-sans text-4xl font-semibold tracking-tight text-[var(--color-ink)] md:text-5xl">
      {d.overviewTitle}
    </h1>
    <p class="mt-4 max-w-2xl text-lg leading-relaxed text-[var(--color-ink-soft)]">
      {OVERVIEW_INTRO[locale]}
    </p>
  </div>
</section>

<section class="mx-auto max-w-3xl px-5 py-12 md:px-8">
  <div class="flex flex-col gap-10">
    {
      OVERVIEW_SECTIONS.map((s) => (
        <div>
          <h2 class="font-sans text-2xl font-semibold tracking-tight text-[var(--color-ink)]">{s.title[locale]}</h2>
          <p class="mt-3 leading-relaxed text-[var(--color-ink-soft)]" set:html={s.body[locale]} />
        </div>
      ))
    }
  </div>
</section>

<section class="border-t border-[var(--color-line)] bg-[var(--color-bg)]">
  <div class="mx-auto max-w-3xl px-5 py-12 md:px-8">
    <h2 class="mb-6 font-sans text-2xl font-semibold tracking-tight text-[var(--color-ink)]">{d.capabilitiesHeading}</h2>
    <div class="grid grid-cols-1 gap-px overflow-hidden rounded-lg border border-[var(--color-line)] bg-[var(--color-line)] sm:grid-cols-2">
      {
        themeCount.map((t) => (
          <a
            href={`${base}/${locale}/${t.id}/`}
            class="group flex flex-col gap-2 bg-[var(--color-surface)] p-6 transition hover:bg-[var(--color-bg)]"
          >
            <div class="flex items-center justify-between">
              <h3 class="font-sans text-base font-semibold text-[var(--color-ink)]">{t.name[locale]}</h3>
              <span class="font-mono text-[11px] text-[var(--color-ink-muted)]">{t.n}</span>
            </div>
            <p class="text-sm leading-relaxed text-[var(--color-ink-soft)]">{t.blurb[locale]}</p>
          </a>
        ))
      }
    </div>
  </div>
</section>
