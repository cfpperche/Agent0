{
  "name": "agent0-mcp-product-pipeline",
  "version": "0.1.0",
  "description": "MCP server owning the 12-step product-planning pipeline (Discovery + Identity + Specification) — Agent0's first capability extension. See docs/specs/025-mcp-product-pipeline/.",
  "private": true,
  "type": "module",
  "main": "src/server.ts",
  "files": [
    "src/",
    "vendor/",
    "design-systems/",
    "schemas/",
    "scripts/",
    "README.md"
  ],
  "scripts": {
    "start": "bun run src/server.ts",
