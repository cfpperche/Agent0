---
import { STRINGS } from "../i18n/strings";
import { REPO_URL, REPO_TREE, type Locale } from "../i18n/locales";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = STRINGS[locale].footer;
const editPagePath = `${REPO_TREE}/site/src/i18n/strings.ts`;
---

<footer class="border-t border-[var(--color-line)] bg-[var(--color-bg)]">
  <div class="mx-auto flex max-w-6xl flex-col gap-6 px-5 py-12 md:flex-row md:items-center md:justify-between md:px-8">
    <div class="flex items-center gap-3">
      <span class="font-mono text-sm font-semibold">
        <span class="text-[var(--color-ink)]">agent0</span><span class="text-[var(--color-accent)]">_</span>
      </span>
      <span class="font-mono text-xs text-[var(--color-ink-muted)]">{t.builtWith}</span>
    </div>
    <nav class="flex flex-wrap items-center gap-4 font-mono text-xs text-[var(--color-ink-soft)]">
      <a href={REPO_URL} target="_blank" rel="noopener" class="hover:text-[var(--color-ink)]">
        {t.repoLink}
      </a>
      <a href={`${REPO_URL}/blob/main/LICENSE`} target="_blank" rel="noopener" class="hover:text-[var(--color-ink)]">
        {t.license}
      </a>
      <a href={editPagePath} target="_blank" rel="noopener" class="hover:text-[var(--color-ink)]">
        {t.editPage}
      </a>
    </nav>
  </div>
</footer>
