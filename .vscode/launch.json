{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Tachyon Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${workspaceFolder}/packages/tachyon/test/fixtures/sample-workspace",
        "--extensionDevelopmentPath=${workspaceFolder}/packages/tachyon"
      ],
      "outFiles": ["${workspaceFolder}/packages/tachyon/dist/**/*.js"],
      "preLaunchTask": "tachyon: build"
    }
  ]
}
