{
  "spec": "163-capacity-kit",
  "roster": ["claude", "codex"],

  "max_rounds": 24,
  "max_repair_attempts": 4,

  "gate": [
    "bash .agent0/tests/diagram/run-all.sh",
    "bash .agent0/tests/transcribe/run-all.sh",
    "bash .agent0/tests/audio/run-all.sh",
    "bash .agent0/tests/sound/run-all.sh",
    "bash .agent0/tests/video/run-all.sh",
    "bash .agent0/tests/capacity-kit/golden.sh verify",
    "bash .agent0/tests/capacity-kit/sync-propagation.sh",
    "bash -n .agent0/tools/lib/capacity.sh .agent0/tools/audio.sh .agent0/tools/sound.sh .agent0/tools/transcribe.sh .agent0/tools/diagram.sh",
    "bash .agent0/tools/doctor.sh"
  ],

  "forbidden_paths": [
    "\\.env",
    "(^|/)secrets?/",
    "\\.secrets?(\\.[^/]+)?$",
    "\\.agent0/.*-audit\\.jsonl",
    "\\.agent0/HANDOFF\\.md"
  ],

  "human_gated_paths": [
    "\\.github/workflows/",
    "migrations/",
    "infra/"
  ]
}
