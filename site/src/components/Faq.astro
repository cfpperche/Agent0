---
import { STRINGS } from "../i18n/strings";
import type { Locale } from "../i18n/locales";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = STRINGS[locale].faq;
---

<section id="faq" class="border-t border-[var(--color-line)] bg-[var(--color-surface)]">
  <div class="mx-auto max-w-4xl px-5 py-20 md:px-8 md:py-28">
    <p class="mb-3 font-mono text-xs uppercase tracking-[0.18em] text-[var(--color-accent)]">
      {t.eyebrow}
    </p>
    <h2 class="mb-10 font-sans text-3xl font-semibold tracking-tight text-[var(--color-ink)] md:text-4xl">
      {t.title}
    </h2>
    <dl class="divide-y divide-[var(--color-line)] border-y border-[var(--color-line)]">
      {
        t.items.map((item) => (
          <details class="group py-5">
            <summary class="flex cursor-pointer list-none items-start justify-between gap-6 text-left">
              <dt class="font-sans text-base font-semibold text-[var(--color-ink)] md:text-lg">
                {item.q}
              </dt>
              <span
                aria-hidden="true"
                class="mt-1 inline-flex h-6 w-6 flex-none items-center justify-center rounded-full border border-[var(--color-line-strong)] font-mono text-sm text-[var(--color-ink-muted)] transition group-open:rotate-45 group-open:border-[var(--color-ink)] group-open:text-[var(--color-ink)]"
              >
                +
              </span>
            </summary>
            <dd class="mt-3 pr-12 text-sm leading-relaxed text-[var(--color-ink-soft)] md:text-base">
              {item.a}
            </dd>
          </details>
        ))
      }
    </dl>
  </div>
</section>
