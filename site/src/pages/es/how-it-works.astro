---
import Doc from "../../layouts/Doc.astro";
import OverviewView from "../../components/OverviewView.astro";
import { DOC_STRINGS } from "../../i18n/docs";
const locale = "es" as const;
const d = DOC_STRINGS[locale];
const title = `${d.overviewTitle} — Agent0`;
const description =
  "Cómo encaja el harness de Agent0: reglas como contexto, hooks como imposición, skills como workflows, y un conjunto de capacidades entre Claude Code y Codex CLI.";
---

<Doc locale={locale} title={title} description={description}>
  <OverviewView locale={locale} />
</Doc>
